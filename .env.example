# Products API – vorton-payement (products were moved from vorton-mob-app)
VITE_API_URL=https://vorton-payement.onrender.com
# Auth & payment – vorton-payement
VITE_API_BASE_URL=https://vorton-payement.onrender.com

# Path to products array (optional; default /api/products)
# VITE_PRODUCTS_PATH=/api/products

# Payment backend (must allow CORS for your site origin)
# VITE_PAYMENT_API_URL=https://vorton-payement.onrender.com
# VITE_PAYMENT_CREATE_PATH=/api/v1/payments/create
# If your backend uses a different path, e.g. /api/order, set VITE_PAYMENT_CREATE_PATH=/api/order

# Auth
# VITE_AUTH_API_URL=https://vorton-payement.onrender.com
# VITE_AUTH_LOGIN_PATH=/auth/login
# VITE_AUTH_SIGNUP_PATH=/auth/signup
# VITE_AUTH_ME_PATH=/api/v1/auth/me

# Cloudinary: required for product images (image names match product skuColor)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_FOLDER=vorton-products
